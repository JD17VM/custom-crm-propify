<odoo>
    <template id="custom_bootstrap_modification" inherit_id="web.webclient_bootstrap" name="Modificación de Bootstrap del WebClient">
        
        <xpath expr="//t[@t-call='web.layout']" position="after">
            <div class="custom-app-banner">
                <div class="contenedor_logos">
                    <div class="contenedor_logo_texto_autonoma">
                        <img src="/custom_crm_propify/static/src/img/Propify_Logo_Blanco.png"/>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <template id="custom_font_loading" inherit_id="web.layout" name="Cargar Fuentes Google">
        <xpath expr="//head" position="inside">
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&amp;family=Roboto:ital,wght@0,100..900;1,100..900&amp;display=swap"/>
        </xpath>
    </template>
</odoo>